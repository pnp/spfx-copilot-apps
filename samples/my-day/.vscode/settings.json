{
  // Configure glob patterns for excluding files and folders in the file explorer.
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/bower_components": true,
    "**/coverage": true,
    "**/jest-output": true,
    "**/lib-amd": true,
    "src/**/*.scss.ts": true
  },
  "typescript.tsdk": ".\\node_modules\\typescript\\lib",
  "chat.tools.terminal.autoApprove": {
    "npm install": true,
    "/^node -e \"const p=require\\('\\./package\\.json'\\); console\\.log\\(p\\.dependencies\\['@fluentui/react-components'\\], p\\.dependencies\\['@fluentui/react-icons'\\]\\)\"$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "heft": true,
    "ForEach-Object": true
  }
}