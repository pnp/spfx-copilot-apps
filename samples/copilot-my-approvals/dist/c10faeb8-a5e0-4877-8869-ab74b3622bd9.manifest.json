  "tools": [
    {
      "name": "MyApprovalsTool",
      "description": {
        "default": "Shows the signed-in user's Microsoft 365 approval requests (from the Approvals app), including who requested each one, its status, and details, and lets the user approve, reject, or re-assign a request, or contact the requester by email, without leaving the conversation. Use this tool whenever the user asks about their approvals or pending requests, wants to see what is waiting for their sign-off, or wants to approve, reject, or otherwise act on an approval."
      },
      "propertiesSchema": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "A message to display."
          }
        },
        "required": [
          "message"
        ],
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
      }
    }
  ],
